# Here you will be able to see port configuration, Data source configurations - let me share some interesting information around the h2 db configuration.
# Since We are going to use a h2 db - which is an in-memory db to store all the details of this accounts ms, by default whenever you perform restarts or shut-downs all the data that we stored will be wiped off.
# But if I want to retain the data, even after restarts and shutdowns, then I need to tell to my h2 db library to store all the data inside a file inside my system so that whenever the restarts or shutdowns happen the data will be read from the file that is stored inside my local hard-disk.
# The below configuration property value of key url is what you need to give. jdbc:h2:file:~ then followed by the file name then semicolon and AUTO_SERVER=true.
# We have also provided the username and pwd, and also we are trying to enable the h2 console.
# We also have some eureka specific properties, actuator related properties, and at last we also have the logging related properties which are going to help us to log the details onto the console by using various colors in the format that we have specified in the configuration - we will see the benefit of this pattern in the coming sessions.
server:
  port: 8081
spring:
  application:
    name: "accounts"
  datasource:
    url: jdbc:h2:file:~/accounts;AUTO_SERVER=true
    driverClassName: org.h2.Driver
    username: sa
    password: ''
  h2:
    console:
      enabled: true
  jpa:
    database-platform: org.hibernate.dialect.H2Dialect
    hibernate:
      ddl-auto: update
    show-sql: true

eureka:
  instance:
    preferIpAddress: true
  client:
    fetchRegistry: true
    registerWithEureka: true
    serviceUrl:
      defaultZone: http://localhost:8070/eureka/

management:
  endpoints:
    web:
      exposure:
        include: "*"
  info:
    env:
      enabled: true

info:
  app:
    name: "accounts"
    description: "Eazy Bank Accounts Application"
    version: "1.0.0"

logging:
  pattern:
    console: "%green(%d{HH:mm:ss.SSS}) %blue(%-5level) %red([%thread]) %yellow(%logger{15}) - %msg%n"